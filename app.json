{
  "expo": {
    "name": "Control Stock",
    "slug": "control-stock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.industrial.controlstock",
      "infoPlist": {
        "NSCameraUsageDescription": "Se necesita acceso a la cámara para escanear códigos de barra."
      }
    },
    "android": {
      "package": "com.industrial.controlstock",
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Se requiere acceso a la cámara para escanear códigos de barra."
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "9206728c-97fd-4fe2-a213-4d10ee127781"
      }
    }
  }
}
